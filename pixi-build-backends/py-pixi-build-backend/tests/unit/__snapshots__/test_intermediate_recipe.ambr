      use_keys: []
      ignore_keys: []
    prefix_detection:
      force_file_type:
        text: []
        binary: []
      ignore: false
      ignore_binary_files: false
    post_process: []
  requirements:
    host:
    - python
    - pip
    - setuptools
    run:
    - pip
  about:
    license: BSD-3-Clause
    license_file:
    - LICENSE
  extra: {}
  source:
  - url:
    - https://github.com/mahmoud/boltons/archive/refs/tags/${{ version }}.tar.gz
    sha256: 9b2998cd9525ed472079c7dd90fbd216a887202e8729d5969d4f33878f0ff668
  
  '''
