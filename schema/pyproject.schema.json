{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pixi.sh/v0.64.0/schema/manifest/pyproject.schema.json",
  "title": "`pyproject.toml` manifest file for `pixi`",
  "type": "object",
  "required": [
    "tool"
  ],
  "properties": {
    "tool": {
      "$ref": "#/$defs/PyProjectToolTable"
    }
  },
  "$defs": {
    "PyProjectToolTable": {
      "title": "PyProjectToolTable",
      "type": "object",
      "properties": {
        "pixi": {
          "description": "`pixi` configuration",
          "anyOf": [
            {
              "required": [
                "project"
              ]
            },
            {
              "required": [
                "workspace"
              ]
            },
            {
              "required": [
                "package"
              ]
            }
          ]
        }
      }
    }
  }
}
