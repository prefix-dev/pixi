---
source: crates/pixi_spec/src/toml.rs
expression: snapshot
---
- label: json_string_matchspec
  input: "{\n  \"version\": \"*\",\n  \"when\": \"__unix\"\n}"
  condition: __unix
- label: json_all
  input: "{\n  \"version\": \"*\",\n  \"when\": {\n    \"all\": [\n      \"__unix\",\n      \"python >=3.10\"\n    ]\n  }\n}"
  condition: (__unix and python>=3.10)
- label: json_any
  input: "{\n  \"version\": \"*\",\n  \"when\": {\n    \"any\": [\n      \"__linux\",\n      \"__osx\"\n    ]\n  }\n}"
  condition: (__linux or __osx)
- label: json_nested_all_any
  input: "{\n  \"version\": \"*\",\n  \"when\": {\n    \"all\": [\n      \"__unix\",\n      {\n        \"any\": [\n          \"__linux\",\n          \"__osx\"\n        ]\n      }\n    ]\n  }\n}"
  condition: (__unix and (__linux or __osx))
- label: json_expanded_build_match
  input: "{\n  \"version\": \"*\",\n  \"when\": {\n    \"package\": \"python\",\n    \"version\": \">=3.10\",\n    \"build\": \"*cuda\"\n  }\n}"
  condition: "python[version=\">=3.10\", build=\"*cuda\"]"
- label: json_expanded_with_build_number
  input: "{\n  \"version\": \"*\",\n  \"when\": {\n    \"package\": \"python\",\n    \"version\": \">=3.10\",\n    \"build-number\": \">=3\"\n  }\n}"
  condition: "python[version=\">=3.10\", build_number=\">=3\"]"
- label: json_expanded_with_subdir
  input: "{\n  \"version\": \"*\",\n  \"when\": {\n    \"package\": \"python\",\n    \"subdir\": \"linux-64\"\n  }\n}"
  condition: "python[subdir=\"linux-64\"]"
- label: json_expanded_with_extras
  input: "{\n  \"version\": \"*\",\n  \"when\": {\n    \"package\": \"python\",\n    \"extras\": [\n      \"dev\"\n    ]\n  }\n}"
  condition: "python[extras=[dev]]"
- label: json_expanded_with_flags
  input: "{\n  \"version\": \"*\",\n  \"when\": {\n    \"package\": \"python\",\n    \"flags\": [\n      \"cuda\",\n      \"blas:*\"\n    ]\n  }\n}"
  condition: "python[flags=[cuda, blas:*]]"
- label: json_expanded_with_track_features
  input: "{\n  \"version\": \"*\",\n  \"when\": {\n    \"package\": \"python\",\n    \"track-features\": [\n      \"legacy\"\n    ]\n  }\n}"
  condition: "python[track_features=\"legacy\"]"
- label: json_expanded_with_file_name
  input: "{\n  \"version\": \"*\",\n  \"when\": {\n    \"package\": \"python\",\n    \"file-name\": \"python-3.10.0-h12debd9_0.tar.bz2\"\n  }\n}"
  condition: "python[fn=\"python-3.10.0-h12debd9_0.tar.bz2\"]"
- label: json_expanded_with_license
  input: "{\n  \"version\": \"*\",\n  \"when\": {\n    \"package\": \"python\",\n    \"license\": \"MIT\",\n    \"license-family\": \"BSD\"\n  }\n}"
  condition: "python[license=\"MIT\", license_family=\"BSD\"]"
- label: toml_all_with_expanded_build_match
  input: "version = \"*\"\nwhen = { all = [\"__unix\", { package = \"python\", version = \">=3.10\", build = \"*cuda\" }] }"
  condition: "(__unix and python[version=\">=3.10\", build=\"*cuda\"])"
- label: toml_any
  input: "version = \"*\"\nwhen = { any = [\"__linux\", \"__osx\"] }"
  condition: (__linux or __osx)
- label: toml_expanded_with_build_number
  input: "version = \"*\"\nwhen = { package = \"python\", version = \">=3.10\", build-number = \">=3\" }"
  condition: "python[version=\">=3.10\", build_number=\">=3\"]"
- label: toml_expanded_with_extras_and_flags
  input: "version = \"*\"\nwhen = { package = \"python\", extras = [\"dev\"], flags = [\"cuda\", \"blas:*\"] }"
  condition: "python[extras=[dev], flags=[cuda, blas:*]]"
- label: toml_expanded_with_track_features
  input: "version = \"*\"\nwhen = { package = \"python\", track-features = [\"legacy\"] }"
  condition: "python[track_features=\"legacy\"]"
