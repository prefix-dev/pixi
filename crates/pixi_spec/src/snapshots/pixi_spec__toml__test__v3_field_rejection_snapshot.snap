- label: json_extras_not_array
  input: "{\n  \"version\": \"*\",\n  \"extras\": \"dev\"\n}"
  error: "invalid type: string \"dev\", expected a sequence"
- label: json_extras_non_string_element
  input: "{\n  \"version\": \"*\",\n  \"extras\": [\n    42\n  ]\n}"
  error: "invalid type: integer `42`, expected a string"
- label: json_flags_not_array
  input: "{\n  \"version\": \"*\",\n  \"flags\": \"cuda\"\n}"
  error: "invalid type: string \"cuda\", expected a sequence"
- label: json_extras_with_path
  input: "{\n  \"path\": \"../foo\",\n  \"extras\": [\n    \"dev\"\n  ]\n}"
  error: "`extras` cannot be used with `path`"
- label: json_flags_with_git
  input: "{\n  \"git\": \"https://example.com/foo.git\",\n  \"flags\": [\n    \"cuda\"\n  ]\n}"
  error: "`flags` cannot be used with `git`"
- label: json_track_features_with_url
  input: "{\n  \"url\": \"https://example.com/foo.conda\",\n  \"track-features\": [\n    \"legacy\"\n  ]\n}"
  error: "`track-features` cannot be used with `url`"
